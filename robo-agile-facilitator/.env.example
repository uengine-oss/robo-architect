## AESF (robo-agile-facilitator) environment example
## Copy these entries into `.env` and fill in real values.

# OpenAI
OPENAI_API_KEY=your_openai_key

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password
# Neo4j 4.x+/5.x multi-database support (optional; default is "neo4j")
NEO4J_DATABASE=neo4j

# Redis
REDIS_URL=redis://localhost:6379

# TURN Server
TURN_SERVER=turn:localhost:3478
TURN_USERNAME=aesf_user
TURN_CREDENTIAL=aesf_turn_pass

# App
DEBUG=true
## Comma-separated
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

