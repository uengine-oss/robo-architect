# =========================
# MSAez - Local Environment
# =========================

# -------------------------
# Neo4j
# -------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=aesf_password_2024
NEO4J_DATABASE=neo4j

# -------------------------
# LLM (LangChain)
# -------------------------
# openai OR anthropic OR google
LLM_PROVIDER=openai

# provider에 맞는 모델명을 넣으세요.
LLM_MODEL=gpt-4.1-2025-04-14

# OpenAI 사용 시 필수
OPENAI_API_KEY=

# Anthropic 사용 시 필수
ANTHROPIC_API_KEY=

# Google 사용 시 필수
GOOGLE_API_KEY=

# -------------------------
# Change Propagation (PoC: 연쇄 전파)
# -------------------------
# /api/change/plan 내부에서 2-hop 컨텍스트를 반복 확장하여 2차~N차 수정 후보를 식별합니다.
# 기본값은 PoC 권장값이며, 운영에서는 비용/성능을 고려해 조정하세요.
CHANGE_PROPAGATION_ENABLED=true
CHANGE_PROPAGATION_MAX_ROUNDS=4
CHANGE_PROPAGATION_MAX_CONFIRMED=60
CHANGE_PROPAGATION_MAX_NEW_PER_ROUND=20
CHANGE_PROPAGATION_MAX_FRONTIER_PER_ROUND=8
CHANGE_PROPAGATION_CONFIRMED_THRESHOLD=0.70
CHANGE_PROPAGATION_REVIEW_THRESHOLD=0.40
# 관계 화이트리스트(쉼표 구분)
CHANGE_PROPAGATION_REL_WHITELIST=IMPLEMENTS,HAS_AGGREGATE,HAS_COMMAND,EMITS,HAS_POLICY,TRIGGERS,INVOKES

# -------------------------
# Ingestion Batch Persist (spec 018)
# -------------------------
# Maximum rows per Neo4j transaction in the ingestion bulk-write helpers.
# 500 is the empirical sweet spot; lower this if you hit transaction-size
# limits on very large entities (e.g. UI sceneGraphs of 100KB+).
INGESTION_BATCH_SIZE=500

# When set to 1, every ingestion bulk flush also writes its input rows to
# `logs/ingestion-snapshots/<session_id>/<phase>.<entity>.json` for offline
# forensics / replay. Default off; turn on for debugging only.
INGESTION_SNAPSHOT_DEBUG=0

# LangChain SQLite cache for ingestion LLM calls. Default ON (=1).
# Set to 0 to disable cache by default at startup. (You can still toggle at
# runtime via POST /api/ingest/cache/enable | /api/ingest/cache/disable.)
INGESTION_CACHE_DEFAULT=1

# Spec 017 — fallback tokenizer when LLM response lacks usage_metadata.
# - tiktoken (default): best accuracy (~1ms/call); cl100k_base for non-OpenAI.
# - heuristic: len(text)//4; zero-cost; lower accuracy.
# - none: skip; call contributes 0 to total but `approximate=true` still flips.
LLM_TOKENIZER_FALLBACK=tiktoken

# -------------------------
# Generation Output Language (spec 031)
# -------------------------
# Server-side default language for LLM-generated natural-language artifacts
# (user-story acceptance criteria, ingestion descriptions, change-plan
# narratives, etc.) when an inbound request carries NO `Accept-Language`
# header (e.g. direct curl, MCP bridge, scripted clients). BCP-47 tag.
#
# The SPA always sends Accept-Language derived from the user's gear-icon
# Settings choice (default = navigator.language), so this fallback only
# fires for non-SPA callers. A single-language team can flip this to their
# language (e.g. ko-KR) without code changes.
GENERATION_LANGUAGE_DEFAULT=en-US


